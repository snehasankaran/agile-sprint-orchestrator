
{
  "type": "object",
  "properties": {
    "itemType": {
      "type": "string",
      "enum": ["Epic", "Story", "Task", "Bug", "Spike"]
    },

    "title": { "type": "string" },

    "description": { "type": "string" },

    "userStory": {
      "type": "object",
      "properties": {
        "persona": { "type": "string" },
        "action": { "type": "string" },
        "benefit": { "type": "string" }
      }
    },

    "businessValue": { "type": "string" },
    "userPersona": { "type": "string" },
    "component": { "type": "string" },
    "riskLevel": {
      "type": "string",
      "enum": ["High", "Medium", "Low"]
    },

    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "given": { "type": "string" },
          "when": { "type": "string" },
          "then": { "type": "string" }
        }
      }
    },

    "testScenarios": {
      "type": "array",
      "items": { "type": "string" }
    },

    "definitionOfDone": {
      "type": "array",
      "items": { "type": "string" }
    },

    "priority": {
      "type": "string",
      "enum": ["High", "Medium", "Low"]
    },

    "storyPoints": { "type": "number" },

    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },

    "traceability": {
      "type": "object",
      "properties": {
        "requirementId": { "type": "string" },
        "feedbackId": { "type": "string" },
        "relatedStoryId": { "type": "string" }
      }
    },

    "bugDetails": {
      "type": "object",
      "properties": {
        "expectedBehavior": { "type": "string" },
        "actualBehavior": { "type": "string" },
        "stepsToReproduce": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": {
          "type": "string",
          "enum": ["High", "Medium", "Low"]
        },
        "environment": { "type": "string" },
        "rootCause": { "type": "string" }
      }
    },

    "taskDetails": {
      "type": "object",
      "properties": {
        "linkedStoryId": { "type": "string" }
      }
    },

    "spikeDetails": {
      "type": "object",
      "properties": {
        "goal": { "type": "string" },
        "output": { "type": "string" },
        "timebox": { "type": "string" }
      }
    },

    "aiInsights": {
      "type": "object",
      "properties": {
        "risks": { "type": "string" },
        "edgeCases": { "type": "string" },
        "suggestions": { "type": "string" }
      }
    }
  },

  "required": ["itemType", "title"]
}